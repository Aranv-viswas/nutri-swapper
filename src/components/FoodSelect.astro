---
/**
 * Themed food picker. A hidden native <select> remains the value source (so the
 * calculator's existing `[data-select-*]` + change-event logic is untouched), and
 * a custom button + listbox popover provides the dark/light-aware UI with search
 * and keyboard navigation. Progressive: the native select carries the real value.
 */
interface Option {
  slug: string;
  name: string;
  glyph: string;
}
interface Props {
  /** "a" | "b" — used for the passthrough data-select-* attr and element ids */
  name: string;
  options: Option[];
  selected: string;
  ariaLabel: string;
  searchPlaceholder: string;
  noResults: string;
}

const { name, options, selected, ariaLabel, searchPlaceholder, noResults } =
  Astro.props as Props;
const nativeAttrs = { [`data-select-${name}`]: "" };
const current = options.find((o) => o.slug === selected) ?? options[0];
const listId = `ns-list-${name}`;
---

<div class="ns-combobox relative inline-block align-middle" data-combobox data-name={name}>
  <select {...nativeAttrs} data-native class="sr-only" aria-hidden="true" tabindex="-1">
    {
      options.map((o) => (
        <option value={o.slug} selected={o.slug === selected}>
          {o.name}
        </option>
      ))
    }
  </select>

  <button
    type="button"
    data-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls={listId}
    aria-label={ariaLabel}
    class="flex items-center gap-2 rounded-sm border border-hairline bg-surface-2 py-1.5 pl-2.5 pr-2 font-medium text-ink outline-none transition-colors hover:border-hairline-strong focus-visible:border-link"
  >
    <span data-trigger-glyph class="text-base leading-none" aria-hidden="true"
      >{current.glyph}</span
    >
    <span data-trigger-label>{current.name}</span>
    <svg
      class="ns-chevron h-3.5 w-3.5 shrink-0 text-mute transition-transform"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
    >
  </button>

  <div
    data-popover
    hidden
    class="ns-popover absolute left-0 top-[calc(100%+6px)] z-50 w-[16rem] max-w-[78vw] overflow-hidden rounded-lg border border-hairline bg-surface shadow-[var(--shadow-float)]"
  >
    <div class="border-b border-hairline p-2">
      <input
        type="text"
        data-filter
        role="combobox"
        aria-expanded="true"
        aria-controls={listId}
        aria-autocomplete="list"
        autocomplete="off"
        placeholder={searchPlaceholder}
        class="w-full rounded-sm bg-surface-2 px-2.5 py-1.5 text-sm text-ink outline-none placeholder:text-mute focus-visible:outline-none"
      />
    </div>
    <ul
      id={listId}
      role="listbox"
      aria-label={ariaLabel}
      class="ns-list max-h-64 overflow-y-auto p-1"
    >
      {
        options.map((o) => (
          <li
            role="option"
            id={`ns-opt-${name}-${o.slug}`}
            data-value={o.slug}
            data-name={o.name}
            data-glyph={o.glyph}
            aria-selected={o.slug === selected}
            class="ns-option flex cursor-pointer items-center gap-2.5 rounded-sm px-2.5 py-2 text-sm text-body"
          >
            <span class="text-base leading-none" aria-hidden="true">
              {o.glyph}
            </span>
            <span class="ns-option-name flex-1 truncate">{o.name}</span>
            <svg
              class="ns-check h-3.5 w-3.5 shrink-0 text-protein"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5" />
            </svg>
          </li>
        ))
      }
    </ul>
    <p data-empty hidden class="px-3 py-3 text-sm text-mute">{noResults}</p>
  </div>
</div>

<style>
  .ns-option .ns-check {
    opacity: 0;
  }
  .ns-option[aria-selected="true"] {
    color: var(--color-ink);
  }
  .ns-option[aria-selected="true"] .ns-check {
    opacity: 1;
  }
  .ns-option.is-active {
    background: var(--color-surface-3);
    color: var(--color-ink);
  }
  [aria-expanded="true"] .ns-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  function enhance(cb: HTMLElement) {
    const $ = <T extends HTMLElement>(s: string) => cb.querySelector<T>(s)!;
    const native = $<HTMLSelectElement>("[data-native]");
    const trigger = $<HTMLButtonElement>("[data-trigger]");
    const popover = $<HTMLElement>("[data-popover]");
    const filter = $<HTMLInputElement>("[data-filter]");
    const empty = $<HTMLElement>("[data-empty]");
    const labelEl = $<HTMLElement>("[data-trigger-label]");
    const glyphEl = $<HTMLElement>("[data-trigger-glyph]");
    const options = Array.from(
      cb.querySelectorAll<HTMLElement>('[role="option"]'),
    );
    let active = -1;

    const visible = () => options.filter((o) => !o.hidden);

    function syncTrigger() {
      const opt = options.find((o) => o.dataset.value === native.value);
      if (!opt) return;
      labelEl.textContent = opt.dataset.name || "";
      glyphEl.textContent = opt.dataset.glyph || "";
      options.forEach((o) =>
        o.setAttribute("aria-selected", String(o === opt)),
      );
    }

    function setActive(i: number) {
      const vis = visible();
      active = vis.length ? Math.max(0, Math.min(i, vis.length - 1)) : -1;
      options.forEach((o) => o.classList.remove("is-active"));
      const cur = vis[active];
      if (cur) {
        cur.classList.add("is-active");
        filter.setAttribute("aria-activedescendant", cur.id);
        cur.scrollIntoView({ block: "nearest" });
      } else {
        filter.removeAttribute("aria-activedescendant");
      }
    }

    function applyFilter(q: string) {
      const needle = q.trim().toLowerCase();
      let any = false;
      options.forEach((o) => {
        const match = (o.dataset.name || "").toLowerCase().includes(needle);
        o.hidden = !match;
        if (match) any = true;
      });
      empty.hidden = any;
      setActive(0);
    }

    function open() {
      if (!popover.hidden) return;
      popover.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      filter.value = "";
      applyFilter("");
      const idx = visible().findIndex((o) => o.dataset.value === native.value);
      setActive(idx >= 0 ? idx : 0);
      filter.focus();
      document.addEventListener("click", onDocClick, true);
    }

    function close() {
      if (popover.hidden) return;
      popover.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
      document.removeEventListener("click", onDocClick, true);
    }

    function onDocClick(e: MouseEvent) {
      if (!cb.contains(e.target as Node)) close();
    }

    function choose(opt: HTMLElement | undefined) {
      if (!opt) return;
      native.value = opt.dataset.value || "";
      native.dispatchEvent(new Event("change", { bubbles: true }));
      close();
      trigger.focus();
    }

    trigger.addEventListener("click", () =>
      popover.hidden ? open() : close(),
    );
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });

    filter.addEventListener("input", () => applyFilter(filter.value));
    filter.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === "Enter") {
        e.preventDefault();
        choose(visible()[active]);
      } else if (e.key === "Escape") {
        e.preventDefault();
        close();
        trigger.focus();
      } else if (e.key === "Tab") {
        close();
      }
    });

    options.forEach((o) => {
      o.addEventListener("click", () => choose(o));
      o.addEventListener("mousemove", () => {
        const i = visible().indexOf(o);
        if (i !== active) setActive(i);
      });
    });

    native.addEventListener("change", syncTrigger);
    syncTrigger();
  }

  document
    .querySelectorAll<HTMLElement>("[data-combobox]")
    .forEach(enhance);
</script>
