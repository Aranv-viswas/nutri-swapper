---
import {
  LOCALES,
  LOCALE_NAMES,
  localizePath,
  useTranslations,
  type Locale,
} from "../i18n/ui.ts";

interface Props {
  lang: Locale;
  /** English canonical path of the current page, for language switching */
  path: string;
  /** False on English-only pages — switcher then points at each locale's home */
  localized?: boolean;
}

const { lang, path, localized = true } = Astro.props;
const t = useTranslations(lang);
const home = localizePath("/", lang);
// Where each language option should go when switching from this page.
const switchTarget = (l: Locale) =>
  localized ? localizePath(path, l) : localizePath("/", l);
---

<header
  class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-[1200px] items-center justify-between px-4 sm:px-6"
  >
    <a href={home} class="flex items-center gap-2" aria-label="Nutri Swapper">
      <span
        class="grid h-7 w-7 place-items-center rounded-md border border-hairline bg-surface font-mono text-sm font-medium text-ink"
        aria-hidden="true">⇄</span
      >
      <span class="text-[15px] font-semibold tracking-tight text-ink"
        >Nutri Swapper</span
      >
    </a>

    <div class="flex items-center gap-1 text-sm">
      <a
        href={`${home}#popular`}
        class="rounded-full px-3 py-1.5 text-body transition-colors hover:bg-surface hover:text-ink"
        >{t("nav.popular")}</a
      >
      <a
        href={`${home}#how`}
        class="hidden rounded-full px-3 py-1.5 text-body transition-colors hover:bg-surface hover:text-ink sm:inline-block"
        >{t("nav.how")}</a
      >
      <a
        href="/about"
        class="hidden rounded-full px-3 py-1.5 text-body transition-colors hover:bg-surface hover:text-ink sm:inline-block"
        >{t("nav.about")}</a
      >
      <a
        href="/contact"
        class="hidden rounded-full px-3 py-1.5 text-body transition-colors hover:bg-surface hover:text-ink sm:inline-block"
        >{t("nav.contact")}</a
      >

      <!-- Language switcher -->
      <details class="group relative" data-lang-menu>
        <summary
          class="flex cursor-pointer list-none items-center gap-1 rounded-full px-2.5 py-1.5 text-body transition-colors hover:bg-surface hover:text-ink"
          aria-label={t("nav.language")}
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"></path>
          </svg>
          <span class="font-mono text-xs uppercase">{lang}</span>
        </summary>
        <ul
          class="absolute right-0 mt-2 min-w-[9rem] overflow-hidden rounded-md border border-hairline bg-surface p-1 shadow-[var(--shadow-float)]"
        >
          {
            LOCALES.map((l) => (
              <li>
                <a
                  href={switchTarget(l)}
                  hreflang={l}
                  aria-current={l === lang ? "true" : undefined}
                  class="flex items-center justify-between rounded-sm px-3 py-1.5 text-sm text-body transition-colors hover:bg-surface-3 hover:text-ink aria-[current]:text-ink"
                >
                  {LOCALE_NAMES[l]}
                  <span class="font-mono text-xs uppercase text-mute">{l}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </details>

      <!-- Theme toggle -->
      <button
        type="button"
        data-theme-toggle
        class="grid h-8 w-8 place-items-center rounded-full border border-hairline bg-surface text-body transition-colors hover:border-hairline-strong hover:text-ink"
        aria-label={t("nav.theme")}
      >
        <svg
          class="theme-icon-sun h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
        <svg
          class="theme-icon-moon h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  // Theme toggle — persist choice, update <meta theme-color>.
  const root = document.documentElement;
  const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
  document
    .querySelector<HTMLButtonElement>("[data-theme-toggle]")
    ?.addEventListener("click", () => {
      const next = root.dataset.theme === "light" ? "dark" : "light";
      root.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch {}
      if (meta) meta.content = next === "light" ? "#ffffff" : "#000000";
    });

  // Close the language dropdown on outside click.
  const menu = document.querySelector<HTMLDetailsElement>("[data-lang-menu]");
  document.addEventListener("click", (e) => {
    if (menu && menu.open && !menu.contains(e.target as Node)) menu.open = false;
  });
</script>
