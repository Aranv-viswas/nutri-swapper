---
import Layout from "../../layouts/Layout.astro";
import SwapCalculator from "../SwapCalculator.astro";
import { SWAP_PAIRS, FOOD_BY_SLUG } from "../../data/foods.ts";
import {
  useTranslations,
  localizePath,
  DEFAULT_LOCALE,
  type Locale,
} from "../../i18n/ui.ts";
import { foodName } from "../../i18n/foods.ts";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const SITE = "https://nutriswapper.com";

const name = (slug: string) => foodName(slug, FOOD_BY_SLUG[slug].name, lang);

// English-only on-page SEO: keyword meta + long-form content + FAQ schema.
const isEn = lang === "en";
const keywords = isEn
  ? "Nutri Swapper, nutri, nutrition, nutri swapper, nutri swap, nutri calculator, nutrition converter, nutri converter, nutri source, calorie swap, protein swap, nutrition swap, density swap calculator, food density swap calculator, nutrition calculator, weight match, macro and caloric density, macro calculator"
  : undefined;

const seoFaqs = [
  {
    q: "What is Nutri Swapper?",
    a: "Nutri Swapper is a free macro and calorie density swap calculator. It tells you the exact weight of a substitute ingredient that matches the protein or calories of the food you ran out of — with no login and nothing to install.",
  },
  {
    q: "How does the Nutri Swapper calculator work?",
    a: "Every food stores its macros per 100 grams. You enter the weight of what you have, pick a replacement, and choose whether to match protein or calories. Nutri Swapper then solves for the gram weight of the substitute and shows a side-by-side macro breakdown.",
  },
  {
    q: "Is Nutri Swapper free to use?",
    a: "Yes. Nutri Swapper is completely free, with no account, no paywall and nothing to download. It works instantly in any modern browser.",
  },
  {
    q: "Do I need to sign up or create an account?",
    a: "No. It is a zero-login nutrition swap tool — open the page and start swapping. We never ask for an email or password.",
  },
  {
    q: "How do I match protein between two ingredients?",
    a: "Select 'match protein' and Nutri Swapper keeps grams of protein identical while solving for weight, using W_b = W_a × (P_a ÷ P_b). It also shows the calorie difference the protein swap creates.",
  },
  {
    q: "How do I match calories instead of protein?",
    a: "Select 'match calories' and the tool holds energy constant with W_b = W_a × (C_a ÷ C_b). You will see how the macros shift — usually more or less protein — at the same calorie count.",
  },
  {
    q: "What is a macro and calorie density swap?",
    a: "It is matching the protein or calories of one food with the correct weight of another. Because Nutri Swapper compares macro and caloric density directly, it works as a density swap calculator and food density swap calculator for everyday ingredient substitutions.",
  },
  {
    q: "Can I use Nutri Swapper on my phone in the kitchen or gym?",
    a: "Yes. The site is mobile-first and loads in under a second, so you can run a quick calorie swap or protein swap mid-recipe or while planning a meal. There is no app to download.",
  },
  {
    q: "How accurate are the nutrition values?",
    a: "Macros are listed per 100 g and based on standard nutrition data. Treat the results as a close, practical estimate for cooking and meal prep rather than lab-grade measurements, since real packaging can vary.",
  },
  {
    q: "Which foods and ingredients can I swap?",
    a: "Nutri Swapper covers 40+ common fitness and kitchen staples — eggs, chicken breast, paneer, tofu, soya chunks, whey protein, greek yogurt, lentils, oats, rice, nuts and more — and you can swap any of them in either direction.",
  },
  {
    q: "What are the most popular ingredient swaps?",
    a: "Common searches include soya chunks to eggs, paneer to tofu, peanuts to roasted chana and whey protein to greek yogurt. Each popular swap has its own page with the calculator pre-loaded.",
  },
  {
    q: "Is Nutri Swapper a nutri grain bar, nutri protein shake or food brand?",
    a: "No. Nutri Swapper is not a food product, nutri grain bars or a nutri protein shake — it is an online nutrition calculator and macro swap tool. If you searched for nutri source, nutri swap or nutri converter to convert one food's macros into another, this is the right tool.",
  },
  {
    q: "Can I use Nutri Swapper for weight loss or a cut?",
    a: "Yes. Use 'match protein' to find a lower-calorie ingredient that keeps your protein the same, or 'match calories' to compare protein density. It is an easy way to trim calories without losing protein on a cut.",
  },
  {
    q: "Does Nutri Swapper work for vegetarian and vegan substitutions?",
    a: "Yes. It includes plant proteins like tofu, tempeh, seitan, soya chunks, lentils and chickpeas, so you can build vegetarian or vegan nutrition swaps that still hit your protein target.",
  },
  {
    q: "Is my data saved or tracked?",
    a: "Nutri Swapper has no accounts, and every calculation runs in your browser — the ingredients and weights you enter are never sent anywhere. We use Google Analytics to measure aggregate, anonymous traffic, and your theme and language preferences are stored locally on your device. See the Privacy Policy for details.",
  },
];

const webApp = {
  "@type": "WebApplication",
  name: "Nutri Swapper",
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  description: t("home.desc"),
  url: SITE + localizePath("/", lang),
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};

const jsonLd = isEn
  ? {
      "@context": "https://schema.org",
      "@graph": [
        webApp,
        {
          "@type": "FAQPage",
          mainEntity: seoFaqs.map((f) => ({
            "@type": "Question",
            name: f.q,
            acceptedAnswer: { "@type": "Answer", text: `<p>${f.a}</p>` },
          })),
        },
      ],
    }
  : { "@context": "https://schema.org", ...webApp };

const steps: Array<[string, string, string]> = [
  ["1", t("step1.t"), t("step1.d")],
  ["2", t("step2.t"), t("step2.d")],
  ["3", t("step3.t"), t("step3.d")],
];
---

<Layout
  title={t("home.title")}
  description={t("home.desc")}
  path="/"
  lang={lang}
  keywords={keywords}
  jsonLd={jsonLd}
>
  <!-- ── Hero + live calculator ─────────────────────────────── -->
  <section class="relative isolate overflow-hidden border-b border-hairline">
    <div class="mesh-bg pointer-events-none absolute inset-0 -z-10"></div>
    <div class="mx-auto max-w-[1100px] px-4 pb-16 pt-16 sm:px-6 sm:pb-24 sm:pt-24">
      <div class="mx-auto max-w-2xl text-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-surface/60 px-3 py-1 font-mono text-xs text-body backdrop-blur"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-protein"></span>
          {t("hero.badge")}
        </span>
        <h1
          class="mt-6 text-[40px] font-semibold leading-[1.05] tracking-[-2px] text-ink sm:text-[56px] sm:tracking-[-2.8px]"
        >
          {t("hero.title1")}<br />
          <span class="gradient-text">{t("hero.title2")}</span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-body sm:text-xl">
          {t("hero.sub")}
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-2xl">
        <SwapCalculator
          defaultA="soya-chunks"
          defaultB="eggs"
          defaultMode="protein"
          lang={lang}
        />
      </div>
    </div>
  </section>

  <!-- ── Popular swaps grid ─────────────────────────────────── -->
  <section id="popular" class="border-b border-hairline">
    <div class="mx-auto max-w-[1100px] px-4 py-16 sm:px-6 sm:py-24">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-wider text-mute">
          // {t("popular.eyebrow")}
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-[-1.28px] text-ink">
          {t("popular.title")}
        </h2>
        <p class="mt-3 text-body">{t("popular.sub")}</p>
      </div>

      <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          SWAP_PAIRS.map(([a, b]) => {
            const fa = FOOD_BY_SLUG[a];
            const fb = FOOD_BY_SLUG[b];
            return (
              <a
                href={localizePath(`/swap/${a}-to-${b}`, lang)}
                class="group flex items-center justify-between rounded-lg border border-hairline bg-surface p-4 transition-colors hover:border-hairline-strong hover:bg-surface-3"
              >
                <span class="flex items-center gap-3">
                  <span class="text-xl" aria-hidden="true">
                    {fa.glyph}
                  </span>
                  <span class="text-sm font-medium text-ink">
                    {name(a)}
                    <span class="px-1.5 font-mono text-mute">→</span>
                    {name(b)}
                  </span>
                  <span class="text-xl" aria-hidden="true">
                    {fb.glyph}
                  </span>
                </span>
                <span class="font-mono text-mute transition-transform group-hover:translate-x-0.5">
                  ↗
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────────── -->
  <section id="how">
    <div class="mx-auto max-w-[1100px] px-4 py-16 sm:px-6 sm:py-24">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-wider text-mute">
          // {t("how.eyebrow")}
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-[-1.28px] text-ink">
          {t("how.title")}
        </h2>
        <p class="mt-3 text-body">{t("how.sub")}</p>
      </div>

      <div class="mt-10 grid gap-4 lg:grid-cols-2">
        <div class="card p-6">
          <p class="font-mono text-xs uppercase tracking-wider text-protein">
            {t("calc.matchProtein")}
          </p>
          <p class="mt-3 text-body">{t("how.matchProteinDesc")}</p>
          <pre
            class="mt-4 overflow-x-auto rounded-md border border-hairline bg-surface-2 p-4 font-mono text-[13px] leading-6 text-ink"><code>W<sub>b</sub> = W<sub>a</sub> × (P<sub>a</sub> / P<sub>b</sub>)</code></pre>
        </div>
        <div class="card p-6">
          <p class="font-mono text-xs uppercase tracking-wider text-energy">
            {t("calc.matchCalories")}
          </p>
          <p class="mt-3 text-body">{t("how.matchCaloriesDesc")}</p>
          <pre
            class="mt-4 overflow-x-auto rounded-md border border-hairline bg-surface-2 p-4 font-mono text-[13px] leading-6 text-ink"><code>W<sub>b</sub> = W<sub>a</sub> × (C<sub>a</sub> / C<sub>b</sub>)</code></pre>
        </div>
      </div>

      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {
          steps.map(([n, h, p]) => (
            <div class="rounded-lg border border-hairline bg-surface p-5">
              <span class="grid h-7 w-7 place-items-center rounded-full border border-hairline font-mono text-sm text-ink">
                {n}
              </span>
              <h3 class="mt-4 text-base font-semibold text-ink">{h}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-body">{p}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ── Long-form SEO content (English) ─────────────────────── */}
  {
    isEn && (
      <section class="border-t border-hairline">
        <article class="mx-auto max-w-[760px] px-4 py-16 sm:px-6 sm:py-24">
          <h2 class="text-3xl font-semibold tracking-[-1.28px] text-ink">
            What is Nutri Swapper?
          </h2>
          <div class="mt-5 space-y-5 text-body leading-relaxed">
            <p>
              <strong class="text-ink">Nutri Swapper</strong> is a free macro and
              calorie density swap calculator built for one job: telling you the
              exact weight of a substitute ingredient that matches the protein or
              calories of the food you ran out of. Instead of a bloated nutrition
              log or a multi-step exchange chart, Nutri Swapper gives you an
              instant, one-to-one weight match. Type the grams of what you have,
              pick a replacement, and the nutri swap calculator solves for the gram
              weight that keeps your target macro identical.
            </p>
            <p>
              Most people open a nutrition calculator only to be pushed through
              sign-ups, onboarding and slow, heavy pages. Nutri Swapper strips all
              of that away. It is a zero-login nutrition swap tool that loads in
              under a second on a phone — exactly when you need it, in the kitchen
              mid-recipe or at the gym planning a meal. Whether you call it a
              calorie swap, a protein swap or a nutrition swap, the math is the same
              and the answer is on screen the moment you type.
            </p>

            <h3 class="pt-2 text-xl font-semibold tracking-[-0.6px] text-ink">
              How the Nutri Swapper calculator works
            </h3>
            <p>
              Every food in the database stores its macros per 100 grams, so the
              nutri converter can compare any two ingredients on equal footing.
              Choose <em class="text-ink not-italic">match protein</em> and Nutri
              Swapper holds grams of protein constant while solving for weight:{" "}
              <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-[13px] text-ink">
                W_b = W_a × (P_a ÷ P_b)
              </code>
              . Choose <em class="text-ink not-italic">match calories</em> and it
              holds energy constant instead:{" "}
              <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-[13px] text-ink">
                W_b = W_a × (C_a ÷ C_b)
              </code>
              . The result is a precise weight match plus a side-by-side macro
              breakdown, so you see exactly what shifts — extra calories on a
              protein swap, or more or less protein on a calorie swap.
            </p>
            <p>
              This makes Nutri Swapper a genuine density swap calculator, not just a
              converter. Because it compares macro and caloric density directly, it
              surfaces the trade-off you actually care about: how much of food B
              equals food A, and what that swap costs or saves you. It works as a
              food density swap calculator for whole ingredients, a macro calculator
              for meal prep, and a quick nutrition converter when a recipe calls for
              something you do not have.
            </p>

            <h3 class="pt-2 text-xl font-semibold tracking-[-0.6px] text-ink">
              Who uses a nutrition swap calculator
            </h3>
            <p>
              Lifters and dieters use Nutri Swapper to keep protein on target when
              an ingredient runs out. Meal-preppers use it to batch-cook around
              what is in the pantry. Home cooks use the nutri calculator to
              substitute one ingredient for another without wrecking a day's totals.
              Common swaps — {" "}
              <a class="text-link hover:underline" href="/swap/soya-chunks-to-eggs">
                soya chunks to eggs
              </a>
              , {" "}
              <a class="text-link hover:underline" href="/swap/paneer-to-tofu">
                paneer to tofu
              </a>
              , {" "}
              <a
                class="text-link hover:underline"
                href="/swap/peanuts-to-roasted-chana"
              >
                peanuts to roasted chana
              </a>{" "}
              and {" "}
              <a
                class="text-link hover:underline"
                href="/swap/whey-protein-to-greek-yogurt"
              >
                whey protein to greek yogurt
              </a>{" "}
              — each have a dedicated page with the calculator pre-loaded, so you
              jump straight to the answer.
            </p>
            <p>
              Why use Nutri Swapper instead of a full macro tracker? A tracker is
              built to log every meal across a day; Nutri Swapper is built for the
              single moment of substitution. When you only need to answer “what
              weight of this equals that,” a dedicated nutri swap calculator is
              faster, lighter and easier than any general nutrition calculator or
              macro calculator app.
            </p>
          </div>

          <h2 class="mt-12 text-2xl font-semibold tracking-[-0.96px] text-ink">
            Nutri Swapper FAQ
          </h2>
          <div class="mt-4 divide-y divide-hairline rounded-lg border border-hairline">
            {seoFaqs.map((f) => (
              <details class="group px-5 py-4">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-medium text-ink">
                  {f.q}
                  <span
                    class="font-mono text-mute transition-transform group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-body">{f.a}</p>
              </details>
            ))}
          </div>
        </article>
      </section>
    )
  }
</Layout>
