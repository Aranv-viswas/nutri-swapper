---
// Self-hosted fonts — no third-party request, no render-blocking <link>. Inter ships
// as a variable wght axis (unicode-range lazy-loads only the Latin woff2 for EN content).
import "@fontsource-variable/inter/wght.css";
import "@fontsource/jetbrains-mono/latin-400.css";
import "@fontsource/jetbrains-mono/latin-500.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
  DEFAULT_LOCALE,
  LOCALES,
  OG_LOCALE,
  alternatesFor,
  localizePath,
  type Locale,
} from "../i18n/ui.ts";

interface Props {
  title: string;
  description: string;
  /** English canonical path, e.g. "/swap/soya-chunks-to-eggs" */
  path?: string;
  lang?: Locale;
  /** Comma-separated keywords for the <meta name="keywords"> tag */
  keywords?: string;
  /** False for English-only utility pages (no /es, /hi variants exist) */
  localized?: boolean;
  /** True to keep the page out of search indexes (error pages) */
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  path = "/",
  lang = DEFAULT_LOCALE,
  keywords,
  localized = true,
  noindex = false,
  jsonLd,
} = Astro.props;
const SITE = "https://nutriswapper.com";
const canonical = SITE + localizePath(path, lang);
// Localized pages advertise every locale; English-only pages advertise just en.
const alternates = localized
  ? alternatesFor(path, SITE)
  : [
      { lang: "en" as Locale, href: SITE + path },
      { lang: "x-default" as Locale, href: SITE + path },
    ];
const ogImage = `${SITE}/web-app-manifest-512x512.png`;
const altLocales = localized ? LOCALES.filter((l) => l !== lang) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="NutriSwapper" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <Fragment>
      <script
        async
        src="https://www.googletagmanager.com/gtag/js?id=G-0E1B7MEJP2"
      ></script>

      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () {
          dataLayer.push(arguments);
        };
        gtag("js", new Date());
        gtag("config", "G-0E1B7MEJP2");
      </script>
    </Fragment>

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Nutri Swapper" />
    <meta
      name="robots"
      content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large"}
    />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#000000" />

    <!-- hreflang alternates for international SEO -->
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.lang} href={alt.href} />
      ))
    }

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nutri Swapper" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    {
      altLocales.map((l) => (
        <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
      ))
    }
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Nutri Swapper — macro & calorie swap calculator" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Nutri Swapper — macro & calorie swap calculator" />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <!-- No-FOUC theme: stamp data-theme before first paint -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme");
          const sys = matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
          document.documentElement.dataset.theme = saved || sys;
        } catch {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
  </head>
  <body>
    <div class="flex min-h-screen flex-col">
      <Header lang={lang} path={path} localized={localized} />
      <main class="flex-1">
        <slot />
      </main>
      <Footer lang={lang} />
    </div>
  </body>
</html>
