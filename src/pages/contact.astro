---
import Layout from "../layouts/Layout.astro";

const title = "Contact Nutri Swapper";
const description =
  "Get in touch with the Nutri Swapper team — suggest a food or swap, report an inaccurate value, or send feedback. We read every message.";
const EMAIL = "arnab47biswas@gmail.com";
---

<Layout title={title} description={description} path="/contact" localized={false}>
  <article class="mx-auto max-w-[760px] px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-wider text-mute">// Contact</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-[-2px] text-ink sm:text-5xl">
      Contact us
    </h1>

    <div class="mt-6 space-y-5 text-body leading-relaxed">
      <p>
        Nutri Swapper is a small, no-login tool — the fastest way to reach us is
        email. We read every message and typically reply within 2–3 business
        days.
      </p>

      <div class="card p-6">
        <p class="font-mono text-xs uppercase tracking-wider text-mute">
          Email us
        </p>
        <a
          class="mt-2 inline-block text-2xl font-semibold tracking-[-0.6px] text-ink hover:underline"
          href={`mailto:${EMAIL}`}>{EMAIL}</a
        >
        <div class="mt-5">
          <a
            href={`mailto:${EMAIL}?subject=Nutri%20Swapper%20feedback`}
            class="inline-flex h-11 items-center rounded-full bg-accent px-5 font-medium text-on-accent transition-opacity hover:opacity-90"
          >
            Send a message
          </a>
        </div>
      </div>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Good reasons to write
      </h2>
      <ul class="list-disc space-y-2 pl-5 marker:text-mute">
        <li>Suggest a new food or ingredient swap you'd like added.</li>
        <li>Report a nutrition value that looks inaccurate.</li>
        <li>Share a bug, a broken page, or a feature idea.</li>
        <li>Partnership, press, or general questions.</li>
      </ul>

      <p class="pt-2">
        For how we handle any details you send, see our
        <a class="text-link hover:underline" href="/privacy">Privacy Policy</a>.
      </p>
    </div>
  </article>
</Layout>
