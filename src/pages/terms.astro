---
import Layout from "../layouts/Layout.astro";

const title = "Terms & Conditions — Nutri Swapper";
const description =
  "The terms of use for Nutri Swapper, a free informational macro and calorie swap calculator. Please read before relying on its results.";
const UPDATED = "June 9, 2026";
const EMAIL = "arnab47biswas@gmail.com";
---

<Layout title={title} description={description} path="/terms" localized={false}>
  <article class="mx-auto max-w-[760px] px-4 py-16 sm:px-6 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-wider text-mute">// Legal</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-[-2px] text-ink sm:text-5xl">
      Terms &amp; Conditions
    </h1>
    <p class="mt-3 font-mono text-xs text-mute">Last updated: {UPDATED}</p>

    <div class="mt-8 space-y-5 text-body leading-relaxed">
      <p>
        By accessing or using Nutri Swapper (the “Service”), you agree to these
        Terms &amp; Conditions. If you do not agree, please do not use the
        Service.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        The service
      </h2>
      <p>
        Nutri Swapper is a free, informational tool that calculates the weight of
        a substitute ingredient needed to match the protein or calories of
        another, using nutrition values stored per 100 grams. It is provided for
        general reference and convenience.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Not medical or dietary advice
      </h2>
      <p>
        Nutri Swapper does not provide medical, nutritional, or dietary advice.
        Its results are not a substitute for professional guidance. Always
        consult a qualified healthcare provider or registered dietitian before
        making decisions about your diet, especially if you have a medical
        condition, allergy, or specific nutritional requirement.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Accuracy of information
      </h2>
      <p>
        Nutrition values are approximate, stated per 100 grams, and based on
        commonly available data. Actual products vary by brand, preparation, and
        packaging. We make no warranty that the figures or calculations are
        complete, current, or error-free, and you use them at your own
        discretion.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Acceptable use
      </h2>
      <p>
        You agree not to misuse the Service, including attempting to disrupt it,
        scrape it at scale, or use it for any unlawful purpose.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Intellectual property
      </h2>
      <p>
        The Nutri Swapper name, design, and content are the property of their
        respective owners and may not be copied or redistributed without
        permission, except as permitted by law.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Disclaimer and limitation of liability
      </h2>
      <p>
        The Service is provided “as is” and “as available,” without warranties of
        any kind. To the fullest extent permitted by law, Nutri Swapper and its
        operators shall not be liable for any direct, indirect, or consequential
        loss arising from your use of, or reliance on, the Service or its results.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Changes to these terms
      </h2>
      <p>
        We may revise these terms from time to time. Continued use of the Service
        after changes take effect constitutes acceptance of the revised terms.
        The “last updated” date above reflects the current version.
      </p>

      <h2 class="pt-4 text-xl font-semibold tracking-[-0.6px] text-ink">
        Contact
      </h2>
      <p>
        Questions about these terms? Email
        <a class="text-link hover:underline" href={`mailto:${EMAIL}`}>{EMAIL}</a>
        or visit our <a class="text-link hover:underline" href="/contact"
          >contact page</a
        >.
      </p>
    </div>
  </article>
</Layout>
